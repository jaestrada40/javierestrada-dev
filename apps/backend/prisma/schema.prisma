datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id          Int      @id @default(autoincrement())
  name        String
  tagline     String
  bio         String
  email       String
  githubUrl   String?  @map("github_url")
  linkedinUrl String?  @map("linkedin_url")
  avatarUrl   String?  @map("avatar_url")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("profile")
}

model SkillCategory {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  gradient  String  @default("violet")
  sortOrder Int     @default(0) @map("sort_order")
  skills    Skill[]

  @@map("skill_category")
}

model Skill {
  id         Int           @id @default(autoincrement())
  name       String
  level      Int           @default(80)
  icon       String?
  featured   Boolean       @default(false)
  sortOrder  Int           @default(0) @map("sort_order")
  categoryId Int           @map("category_id")
  category   SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("skill")
}

model Project {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  stack       String  // tecnologías separadas por coma
  githubUrl   String? @map("github_url")
  demoUrl     String? @map("demo_url")
  featured    Boolean @default(false)
  sortOrder   Int     @default(0) @map("sort_order")

  @@map("project")
}

model Experience {
  id           Int     @id @default(autoincrement())
  kind         String  // "work" | "education"
  title        String
  organization String
  startYear    Int     @map("start_year")
  endYear      Int?    @map("end_year") // null = actualidad
  description  String
  sortOrder    Int     @default(0) @map("sort_order")

  @@map("experience")
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("post")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password      String
  mfaSecret     String?  @map("mfa_secret")
  mfaEnabled    Boolean  @default(false) @map("mfa_enabled")
  recoveryCodes String?  @map("recovery_codes")
  tokenVersion  Int      @default(0) @map("token_version")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("user")
}
